{
  "name": "simple-workout-backup",
  "private": true,
  "version": "1.0.0",
  "description": "Cloudflare Worker backend for Simple Workout backup/restore",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:init:local": "wrangler d1 execute workout-backups --local --file=./schema.sql",
    "db:init:remote": "wrangler d1 execute workout-backups --remote --file=./schema.sql"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250620.0",
    "typescript": "^5.6.3",
    "wrangler": "^4.0.0"
  }
}
